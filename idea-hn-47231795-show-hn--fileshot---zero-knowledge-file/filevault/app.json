{
  "expo": {
    "name": "FileVault",
    "slug": "filevault",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourcompany.filevault"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.yourcompany.filevault"
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "scheme": "filevault",
    "plugins": [
      [
        "expo-crypto",
        {
          "crypto": true,
          "rsa": true
        }
      ],
      "expo-file-system",
      "expo-sqlite",
      "expo-image-picker",
      "expo-document-picker",
      "expo-sharing",
      "expo-task-manager",
      "react-native-quick-crypto"
    ]
  }
}
