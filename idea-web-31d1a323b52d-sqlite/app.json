{
  "expo": {
    "name": "DataPal",
    "slug": "datapal",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "DataPal needs microphone access for voice-to-text database creation and queries.",
        "NSSpeechRecognitionUsageDescription": "DataPal uses speech recognition to convert your voice commands into database operations."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-sqlite",
        {
          "iosDatabaseLocation": "Library/Preferences"
        }
      ],
      "expo-speech",
      [
        "expo-av",
        {
          "microphonePermission": "Allow DataPal to access your microphone for voice commands."
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow DataPal to access your microphone.",
          "speechRecognitionPermission": "Allow DataPal to use speech recognition."
        }
      ]
    ]
  }
}
