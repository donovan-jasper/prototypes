{
  "name": "flowguard",
  "version": "1.0.0",
  "description": "Stay focused longer — your phone detects when you're drifting off and gently brings you back to what matters.",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg)"
    ]
  },
  "dependencies": {
    "@react-navigation/bottom-tabs": "^6.5.2",
    "@react-navigation/native": "^6.1.7",
    "expo": "~52.0.0",
    "expo-av": "~13.10.0",
    "expo-background-fetch": "~12.6.0",
    "expo-notifications": "~0.27.0",
    "expo-sensors": "~13.4.0",
    "expo-sqlite": "~12.6.0",
    "expo-task-manager": "~12.6.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.72.6",
    "react-native-svg": "13.9.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.3.0",
    "@types/jest": "^29.5.0",
    "@types/react": "~18.2.45",
    "jest": "^29.2.1",
    "typescript": "^5.1.3"
  },
  "private": true
}
