{
  "name": "querymentor",
  "version": "1.0.0",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "eject": "expo eject",
    "test": "jest"
  },
  "dependencies": {
    "expo": "~49.0.0",
    "expo-sqlite": "~11.3.0",
    "expo-speech": "~11.2.0",
    "expo-av": "~13.4.0",
    "react": "18.2.0",
    "react-native": "0.72.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/preset-env": "^7.20.0",
    "@babel/preset-react": "^7.18.0",
    "@babel/preset-typescript": "^7.21.0",
    "@testing-library/react-native": "^12.0.0",
    "@types/jest": "^29.5.0",
    "@types/react": "~18.0.14",
    "@types/react-native": "~0.71.0",
    "jest": "^29.2.1",
    "react-test-renderer": "18.2.0",
    "typescript": "^4.6.3"
  },
  "jest": {
    "preset": "react-native",
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx"
    ],
    "transform": {
      "^.+\\.(js|jsx|ts|tsx)$": "babel-jest"
    },
    "testMatch": [
      "**/tests/**/*.test.(ts|tsx|js|jsx)"
    ],
    "collectCoverageFrom": [
      "app/**/*.{ts,tsx}",
      "!app/**/*.d.ts"
    ]
  },
  "private": true
}
