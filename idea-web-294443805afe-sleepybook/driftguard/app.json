{
  "expo": {
    "name": "DriftGuard",
    "slug": "driftguard",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourcompany.driftguard"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.yourcompany.driftguard"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "permissions": [
      "RECORD_AUDIO",
      "VIBRATE",
      "RECEIVE_BOOT_COMPLETED"
    ],
    "backgroundModes": [
      "audio",
      "fetch"
    ]
  }
}
