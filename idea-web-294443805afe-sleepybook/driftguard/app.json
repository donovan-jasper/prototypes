{
  "expo": {
    "name": "DriftGuard",
    "slug": "driftguard",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourcompany.driftguard"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.yourcompany.driftguard"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-sensors",
        {
          "motionPermission": "Allow $(PRODUCT_NAME) to access motion and fitness data."
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Allow $(PRODUCT_NAME) to access microphone."
        }
      ],
      [
        "expo-brightness",
        {
          "brightnessPermission": "Allow $(PRODUCT_NAME) to adjust screen brightness."
        }
      ],
      [
        "expo-sqlite",
        {
          "iosDatabaseLocation": "Library/Application Support"
        }
      ],
      [
        "expo-background-fetch",
        {
          "backgroundFetchPermission": "Allow $(PRODUCT_NAME) to run in the background."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#ffffff"
        }
      ],
      [
        "expo-sms",
        {
          "smsPermission": "Allow $(PRODUCT_NAME) to send SMS messages."
        }
      ]
    ],
    "permissions": [
      "CAMERA",
      "MICROPHONE",
      "VIBRATE",
      "SEND_SMS"
    ]
  }
}
